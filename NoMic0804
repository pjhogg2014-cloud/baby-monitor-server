// ================================================================
// I²S SETUP
// [FIX 2] Changed to I2S_BITS_PER_SAMPLE_32BIT.
// The INMP441 outputs MSB-aligned 24-bit values in 32-bit I²S
// frames (bits 31–8 carry audio; bits 7–0 are always zero).
// Reading 16-bit captures only the upper half of the 32-bit
// slot — on the INMP441 these are the zero-padding and sign-
// extension bits, not audio data, producing silence.
// We read 32-bit, shift right 8 bits to recover the 24-bit
// value, then cast to int16_t, discarding the bottom 8 bits of
// the 24-bit value. This yields clean 16-bit PCM suitable for
// streaming with no audible quality loss for monitoring use.
// ================================================================
void setupI2S() {
    i2s_config_t i2s_config = {
    .mode                 = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate          = SAMPLE_RATE,
    .bits_per_sample      = I2S_BITS_PER_SAMPLE_32BIT,
    .channel_format       = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = (i2s_comm_format_t)(I2S_COMM_FORMAT_I2S | I2S_COMM_FORMAT_I2S_MSB),
    .intr_alloc_flags     = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count        = 4,
    .dma_buf_len          = AUDIO_BUF_LEN,
    .use_apll             = false,
    .tx_desc_auto_clear   = false,
    .fixed_mclk           = 0
};

    i2s_pin_config_t pin_config = {
        .bck_io_num   = I2S_SCK,
        .ws_io_num    = I2S_WS,
        .data_out_num = I2S_PIN_NO_CHANGE,
        .data_in_num  = I2S_SD
    };
    i2s_driver_install(I2S_NUM_1, &i2s_config, 0, NULL);
    i2s_set_pin(I2S_NUM_1, &pin_config);
    i2s_zero_dma_buffer(I2S_NUM_1);
    Serial.println("I2S microphone ready (32-bit mode).");
}

// ================================================================
// AUDIO WEBSOCKET — connect
// ================================================================
bool connectAudio() {
    audioTls.stop();
    audioTls.setInsecure();
    if (!audioTls.connect(AUDIO_SERVER_HOST, AUDIO_SERVER_PORT)) {
        Serial.println("[AUDIO] Server connect failed.");
        return false;
    }

    // [FIX 1 note] The Sec-WebSocket-Key must be a random 16-byte
    // value encoded as base64. Using the RFC example key
    // ("dGhlIHNhbXBsZSBub25jZQ==") is legal — servers must not
    // interpret its content — but some implementations flag it.
    // A random key is cleaner; we generate one here.
    uint8_t keyBytes[16];
    for (int i = 0; i < 16; i++) keyBytes[i] = random(0, 256);
    // Base64-encode keyBytes manually (no extra library needed)
    static const char b64chars[] =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
    // 16 bytes base64-encodes to exactly 24 characters:
    //   bytes  0–14 → 5 groups of 3 → 20 chars  (loop below)
    //   byte  15    → 1 remaining   →  2 chars + "==" (after loop)
    // Previous code had i < 12, encoding only bytes 0–11 and leaving
    // wsKey[16..21] as zero bytes. The server truncates at the first
    // null and rejects the malformed key with HTTP 400.
    char wsKey[25] = {0};
    for (int i = 0, j = 0; i < 15; i += 3, j += 4) {   // i < 15, not i < 12
        uint32_t v = ((uint32_t)keyBytes[i]   << 16)
                   | ((uint32_t)keyBytes[i+1] <<  8)
                   | (uint32_t)keyBytes[i+2];
        wsKey[j]   = b64chars[(v >> 18) & 0x3F];
        wsKey[j+1] = b64chars[(v >> 12) & 0x3F];
        wsKey[j+2] = b64chars[(v >>  6) & 0x3F];
        wsKey[j+3] = b64chars[ v        & 0x3F];
    }
    // Remaining byte 15: 2 base64 chars + "=="
    wsKey[20] = b64chars[(keyBytes[15] >> 2) & 0x3F];
    wsKey[21] = b64chars[((keyBytes[15] & 0x03) << 4) & 0x3F];
    wsKey[22] = '=';
    wsKey[23] = '=';
    wsKey[24] = '\0';

    audioTls.printf(
        "GET %s HTTP/1.1\r\n"
        "Host: %s\r\n"
        "Upgrade: websocket\r\n"
        "Connection: Upgrade\r\n"
        "Sec-WebSocket-Key: %s\r\n"
        "Sec-WebSocket-Version: 13\r\n"
        "\r\n",
        AUDIO_SERVER_PATH, AUDIO_SERVER_HOST, wsKey
    );

    String response = "";
    unsigned long t = millis();
    while (millis() - t < 3000) {
        if (audioTls.available()) {
            String line = audioTls.readStringUntil('\n');
            response += line;
            if (line == "\r") break;
        }
        delay(1);
    }
    if (response.indexOf("101") > 0) {
        Serial.println("[AUDIO] WebSocket connected.");
        return true;
    }
    Serial.println("[AUDIO] WebSocket handshake failed: " + response.substring(0, 80));
    return false;
}

// ================================================================
// SEND AUDIO WEBSOCKET FRAME
//
// [FIX 1] RFC 6455 §5.3 requires ALL client-to-server frames to
// be masked with a 4-byte XOR key included in the frame header.
// The MASK bit (0x80) must be set in the second header byte.
// Without masking, the Node.js ws library closes the socket
// immediately with code 1002 (protocol error). The previous
// version set header[0] = 0x82 (correct: FIN + binary opcode)
// but set header[1] = len with no MASK bit, and never applied
// the XOR transform. This caused the server to drop the
// connection on the first audio frame.
//
// Frame structure (binary, len ≤ 65535):
//   Byte 0: 0x82  — FIN=1, RSV=0, opcode=2 (binary)
//   Byte 1: 0x80 | len  or  0x80 | 126 + 2-byte len
//   [Bytes 2-3: extended 16-bit length if len > 125]
//   Bytes n to n+3: 4-byte masking key (random)
//   Remaining: payload XOR'd byte-by-byte with masking key
//              using mask[i % 4]
// ================================================================
void sendAudioFrame(uint8_t* data, size_t len) {
    if (!audioTls.connected()) return;

    // Generate a fresh 4-byte random masking key for this frame.
    // RFC 6455 §10.3: key must be unpredictable — esp_random()
    // provides hardware RNG output on the ESP32-S3.
    uint32_t maskWord = esp_random();
    uint8_t  mask[4];
    memcpy(mask, &maskWord, 4);

    // Build header
    uint8_t header[8];
    int headerLen = 0;
    header[0] = 0x82;                    // FIN + binary opcode

    if (len <= 125) {
        header[1] = 0x80 | (uint8_t)len;  // MASK bit set
        headerLen = 2;
    } else {
        header[1] = 0x80 | 126;            // MASK bit + 16-bit length indicator
        header[2] = (len >> 8) & 0xFF;
        header[3] = len & 0xFF;
        headerLen = 4;
    }

    // Append masking key immediately after the length field
    memcpy(header + headerLen, mask, 4);
    headerLen += 4;

    audioTls.write(header, headerLen);

    // Write payload in 64-byte chunks to avoid a large stack buffer.
    // Each byte is XOR'd with mask[i % 4] where i is the byte index
    // within the payload (not the frame).
    uint8_t maskedChunk[64];
    size_t  sent = 0;
    while (sent < len) {
        size_t chunkSize = min(len - sent, (size_t)64);
        for (size_t i = 0; i < chunkSize; i++) {
            maskedChunk[i] = data[sent + i] ^ mask[(sent + i) & 3];
        }
        audioTls.write(maskedChunk, chunkSize);
        sent += chunkSize;
    }
}

