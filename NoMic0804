        "</body></html>";

    sendSmtpEmail(condition, textBody, htmlBody);
}

// ================================================================
// ALERT EVALUATION — all conditions, individual cooldowns
// ================================================================
void evaluateAlerts(float objectTemp) {
    unsigned long now = millis();
    bool gracePeriodOver = (now > INIT_GRACE_PERIOD);

    // Temperature
    if (objectTemp > FEVER_THRESHOLD) {
        if (now - lastTempAlertTime >= ALERT_COOLDOWN) {
            sendAlert(objectTemp,
                "Fever detected: " + String(objectTemp, 1) + " C");
            lastTempAlertTime = now;
        }
    } else if (objectTemp < HYPO_THRESHOLD && objectTemp > 20.0f) {
        if (now - lastTempAlertTime >= ALERT_COOLDOWN) {
            sendAlert(objectTemp,
                "Low temperature: " + String(objectTemp, 1) + " C");
            lastTempAlertTime = now;
        }
    }

    if (!gracePeriodOver) return;

    // Apnea / no detection
    if (!radarDetected &&
        (now - lastDetectedTime >= NO_DETECT_TIMEOUT)) {
        if (now - lastApneaTime >= ALERT_COOLDOWN) {
            sendAlert(objectTemp,
                "Breathing not detected — possible apnea ("
                + String(NO_DETECT_TIMEOUT / 1000) + " s)");
            lastApneaTime = now;
        }
    }

    // Breathing rate
    if (radarDetected && currentBreathing > 0) {
        if (currentBreathing < BRADYPNOEA_THRESHOLD) {
            if (now - lastBradypnoeaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "Low breathing rate: " + String(currentBreathing, 0) + " bpm");
                lastBradypnoeaTime = now;
            }
        } else if (currentBreathing > TACHYPNOEA_THRESHOLD) {
            if (now - lastTachypnoeaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "High breathing rate: " + String(currentBreathing, 0) + " bpm");
                lastTachypnoeaTime = now;
            }
        }
    }

    // Heart rate
    if (radarDetected && currentHeartRate > 0) {
        if (currentHeartRate < BRADYCARDIA_THRESHOLD) {
            if (now - lastBradycardiaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "Low heart rate: " + String(currentHeartRate, 0) + " bpm");
                lastBradycardiaTime = now;
            }
        } else if (currentHeartRate > TACHYCARDIA_THRESHOLD) {
            if (now - lastTachycardiaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "High heart rate: " + String(currentHeartRate, 0) + " bpm");
                lastTachycardiaTime = now;
            }
        }
    }
}

// ================================================================
// MQTT PUBLISH — temperature and radar topics
// ================================================================
void publishSensorData(float objectTemp, float ambientTemp) {
    char buf[256];

    snprintf(buf, sizeof(buf),
        "{\"object\":%.1f,\"ambient\":%.1f,\"ts\":%lu}",
        objectTemp, ambientTemp, (unsigned long)time(nullptr));
    mqttClient.publish(TOPIC_TEMPERATURE, buf);

    snprintf(buf, sizeof(buf),
        "{\"breathing\":%.0f,\"heartrate\":%.0f,"
        "\"distance\":%.2f,\"detected\":%s,\"ts\":%lu}",
        currentBreathing, currentHeartRate, currentDistance,
        radarDetected ? "true" : "false",
        (unsigned long)time(nullptr));
    mqttClient.publish(TOPIC_RADAR, buf);

    Serial.printf("[MQTT] Temp: %.1f C | BR: %.0f bpm | HR: %.0f bpm | "
                  "Detected: %s\n",
                  objectTemp, currentBreathing, currentHeartRate,
                  radarDetected ? "Yes" : "No");
}

// ================================================================
// DNS helper — wait for resolution before MQTT connect
// ================================================================
void waitForDNS() {
    Serial.print("Waiting for DNS");
    IPAddress addr;
    int attempts = 0;
    while (!WiFi.hostByName(MQTT_HOST, addr) && attempts < 20) {
        delay(500);
        Serial.print(".");
        attempts++;
    }
    Serial.printf("\nDNS resolved: %s → %s\n",
                  MQTT_HOST, addr.toString().c_str());
}

// ================================================================
// SETUP
// ================================================================
void setup() {
    Serial.begin(115200);

    // ── Camera FIRST ────────────────────────────────────────────
    // The camera DMA allocator requires a single contiguous block
    // in PSRAM. mbedTLS (used by MQTT and audio WebSocket TLS)
    // fragments PSRAM with many small allocations during the
    // handshake. If the camera is initialised after those TLS
    // sessions are live, the contiguous block no longer exists and
    // esp_camera_init fails with 0xffffffff (ESP_ERR_NO_MEM).
    // Initialising the camera before any network connections
    // guarantees the allocation succeeds on fresh, unfragmented heap.
    initCamera();

    // ── I²C — MLX90614 ──────────────────────────────────────────
    Wire.begin(I2C_SDA, I2C_SCL);
    if (!mlx.begin()) {
        Serial.println("ERROR: MLX90614 not found.");
        while (true) delay(1000);
    }
    Serial.println("MLX90614 ready.");

    // Radar UART
    mmWaveSerial.begin(115200, SERIAL_8N1, RADAR_RX, RADAR_TX);
    mmWave.begin(&mmWaveSerial);
    lastDetectedTime = millis();
    Serial.println("MR60BHA2 radar initialised.");

    // I²S — INMP441 (32-bit mode, see FIX 2)
    setupI2S();

    // Wi-Fi
    Serial.printf("Connecting to %s", WIFI_SSID);
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
    }
    Serial.printf("\nConnected. IP: %s\n",
                  WiFi.localIP().toString().c_str());
    delay(500);

    // NTP — change offset to 3600 during BST (March–October)
    configTime(3600, 0, "pool.ntp.org", "time.nist.gov");
    Serial.print("Syncing NTP");
    time_t now = time(nullptr);
    while (now < 100000) { delay(200); Serial.print("."); now = time(nullptr); }
    Serial.println("\nTime synced.");

    // MQTT
    waitForDNS();
    mqttTls.setInsecure();
    mqttClient.setServer(MQTT_HOST, MQTT_PORT);
    mqttClient.setKeepAlive(15);
    mqttClient.setBufferSize(512);
    mqttClient.setSocketTimeout(30);

    Serial.println("Connecting to MQTT...");
    int attempts = 0;
    while (!mqttClient.connect(MQTT_CLIENT, MQTT_USER, MQTT_PASS)
           && attempts < 10) {
        Serial.printf("MQTT state: %d\n", mqttClient.state());
        delay(2000);
        attempts++;
    }
    Serial.println(mqttClient.connected()
                   ? "MQTT connected."
                   : "MQTT failed — continuing without.");

    // Audio + Video WebSocket
    audioConnected = connectAudio();
    videoConnected = connectVideo();

    Serial.println("System ready — monitoring started.");
}

// ================================================================
// LOOP
// ================================================================
void loop() {
    // ---- MQTT keepalive ----
    // BUG 5 FIX: previously called mqttClient.connect() on every loop()
    // pass with no rate limiting. PubSubClient.connect() is blocking and
    // waits up to setSocketTimeout() seconds (30 s) per attempt on failure.
    // This froze audio capture, video sending, and radar polling for 30 s
    // every time MQTT disconnected. Fixed with a 5-second retry timer.
    if (!mqttClient.connected()) {
        static unsigned long lastMqttRetry = 0;
        if (millis() - lastMqttRetry >= 5000UL) {
            lastMqttRetry = millis();
            Serial.println("[MQTT] Reconnecting...");
            mqttClient.connect(MQTT_CLIENT, MQTT_USER, MQTT_PASS);
        }
    }
    mqttClient.loop();

    unsigned long now = millis();

    // ---- Audio: capture and stream ----
    // [FIX 2] Raw buffer is int32_t. We shift right 8 bits to
    // recover the 24-bit audio value, then cast to int16_t.
    // i2s_read timeout = 0 (non-blocking) keeps the loop responsive.
    if (audioConnected && audioTls.connected()) {
    // Static buffers — declared static to avoid allocating 3KB on the
    // loop() stack on every iteration. The loop task stack is limited
    // and with TLS, camera, and radar all active, local allocation here
    // would eventually cause a stack overflow.
    static int32_t rawBuf[AUDIO_BUF_LEN];
    static int16_t audioBuf[AUDIO_BUF_LEN];
        size_t bytesRead = 0;

        i2s_read(I2S_NUM_1
        , rawBuf, sizeof(rawBuf), &bytesRead, 0);

        //CHANGED 17:05
                                   if (bytesRead > 0) {
                                   Serial.println(String(rawBuf[0]) + " " + String(rawBuf[1]) + " " + String(rawBuf[2]) + " " + String(rawBuf[3]));
                                                      }
        
        if (bytesRead > 0) {
            int samples = bytesRead / 4;          // 4 bytes per int32_t word
            for (int i = 0; i < samples; i++) {
                audioBuf[i] = (int16_t)(rawBuf[i] >> 14);
            }
            sendAudioFrame((uint8_t*)audioBuf, samples * sizeof(int16_t));
        }
    }

    // ---- Audio reconnection — non-blocking, every 10 s ----
    if (!audioConnected || !audioTls.connected()) {
        if (now - lastAudioReconnect >= AUDIO_RECONNECT_INTERVAL) {
            lastAudioReconnect = now;
            Serial.println("[AUDIO] Reconnecting...");
            audioConnected = connectAudio();
        }
    }

    // ---- Video: capture one JPEG frame and send to Render /video ----
    // Throttled to VIDEO_FRAME_INTERVAL_MS (200 ms = 5 fps).
    // esp_camera_fb_get() is non-blocking when fb_count=1 and
    // grab_mode=CAMERA_GRAB_WHEN_EMPTY — it returns immediately
    // with a fresh frame if one is available, or the previous frame.
    // esp_camera_fb_return() MUST always be called to release the
    // buffer back to the DMA pool, even if the send fails.
    if (videoConnected && videoTls.connected()) {
        if (now - lastVideoFrame >= VIDEO_FRAME_INTERVAL_MS) {
            lastVideoFrame = now;
            camera_fb_t* fb = esp_camera_fb_get();
            if (fb) {
                sendVideoFrame(fb->buf, fb->len);
                esp_camera_fb_return(fb);
            }
        }
    }

    // ---- Video reconnection — non-blocking, every 10 s ----
    if (!videoConnected || !videoTls.connected()) {
        if (now - lastVideoReconnect >= VIDEO_RECONNECT_INTERVAL) {
            lastVideoReconnect = now;
            Serial.println("[VIDEO] Reconnecting...");
            videoConnected = connectVideo();
        }
    }

    // ---- Radar — poll continuously ----
    updateRadar();

    // ---- Sensor read + publish + alert (on interval) ----
    if (now - lastReadTime < READING_INTERVAL) return;
    lastReadTime = now;

    float objectTemp  = mlx.readObjectTempC();
    float ambientTemp = mlx.readAmbientTempC();

    Serial.printf("[MLX] Object: %.1f C | Ambient: %.1f C\n",
                  objectTemp, ambientTemp);

    // Guard against NaN and implausible values
    if (isnan(objectTemp) || isnan(ambientTemp) ||
        objectTemp > 50.0f || objectTemp < 20.0f) {
        Serial.println("[MLX] Invalid reading — skipped.");
        return;
    }

    publishSensorData(objectTemp, ambientTemp);
    evaluateAlerts(objectTemp);
}
