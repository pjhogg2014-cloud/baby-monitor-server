void sendAlert(float objectTemp, String condition) {
    Serial.println("[ALERT] " + condition);

    // MQTT alert payload
    char alertBuf[256];
    snprintf(alertBuf, sizeof(alertBuf),
        "{\"condition\":\"%s\","
        "\"temperature\":%.1f,"
        "\"breathing\":%.0f,"
        "\"heartrate\":%.0f,"
        "\"detected\":%s,"
        "\"ts\":%lu}",
        condition.c_str(), objectTemp,
        currentBreathing, currentHeartRate,
        radarDetected ? "true" : "false",
        (unsigned long)time(nullptr));
    mqttClient.publish(TOPIC_ALERT, alertBuf);

    // Plain-text email body
    String textBody =
        "Baby Monitor Alert\n\n"
        "Condition       : " + condition + "\n"
        "Temperature     : " + String(objectTemp, 1) + " C\n"
        "Breathing rate  : " + String(currentBreathing, 0) + " bpm\n"
