        "Subject detected: " + String(radarDetected ? "Yes" : "No") + "\n"
        "Distance        : " + String(currentDistance, 2) + " m\n\n"
        "Please check on the infant.\n\n"
        "Note: each alert condition is suppressed for 5 minutes after firing.\n"
        "-- Baby Monitor System";

    // HTML email body
    String htmlBody =
        "<html><body style='font-family:sans-serif;max-width:520px;'>"
        "<h2 style='color:#c0392b;'>Baby Monitor Alert</h2>"
        "<p><strong>" + condition + "</strong></p>"
        "<table style='border-collapse:collapse;width:100%;'>"
        "<tr style='background:#f8f8f8;'>"
        "<td style='padding:8px 12px;font-weight:bold;'>Temperature</td>"
        "<td style='padding:8px 12px;color:#c0392b;font-size:18px;'>"
        + String(objectTemp, 1) + " &deg;C</td></tr>"
        "<tr><td style='padding:8px 12px;font-weight:bold;'>Breathing rate</td>"
        "<td style='padding:8px 12px;'>" + String(currentBreathing, 0) + " bpm</td></tr>"
        "<tr style='background:#f8f8f8;'>"
        "<td style='padding:8px 12px;font-weight:bold;'>Heart rate</td>"
        "<td style='padding:8px 12px;'>" + String(currentHeartRate, 0) + " bpm</td></tr>"
        "<tr><td style='padding:8px 12px;font-weight:bold;'>Subject detected</td>"
        "<td style='padding:8px 12px;'>"
        + String(radarDetected ? "Yes" : "No") + "</td></tr>"
