// Send one JPEG frame as a masked binary WebSocket message.
// JPEG frames can be 5-15 KB, so a 16-bit extended length header is used.
// The masking loop is identical to sendAudioFrame.
void sendVideoFrame(uint8_t* data, size_t len) {
    if (!videoTls.connected()) return;

    uint32_t maskWord = esp_random();
    uint8_t  mask[4];
    memcpy(mask, &maskWord, 4);

    // 16-bit extended length header (len will exceed 125 for any JPEG)
    uint8_t header[8];
    header[0] = 0x82;           // FIN + binary opcode
    header[1] = 0x80 | 126;    // MASK + 16-bit extended length
    header[2] = (len >> 8) & 0xFF;
    header[3] = len & 0xFF;
    memcpy(header + 4, mask, 4);
    videoTls.write(header, 8);

    uint8_t chunk[128];        // larger chunk size than audio — JPEG data is sequential
    size_t sent = 0;
    while (sent < len) {
        size_t sz = min(len - sent, (size_t)128);
        for (size_t i = 0; i < sz; i++)
            chunk[i] = data[sent + i] ^ mask[(sent + i) & 3];
        videoTls.write(chunk, sz);
        sent += sz;
    }
}
