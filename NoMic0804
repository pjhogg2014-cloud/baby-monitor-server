// ================================================================
// DIRECT SMTP OVER SMTPS — replaces ReadyMail
//
// Brevo port 465 is SMTPS: TLS is negotiated on connection,
// before any SMTP dialogue. WiFiClientSecure handles this
// identically to any other TLS connection.
//
// Protocol flow:
//   Connect (TLS) → 220 greeting
//   EHLO           → 250 (multi-line, drained below)
//   AUTH LOGIN     → 334 → send b64(user) → 334 → send b64(pass) → 235
//   MAIL FROM      → 250
//   RCPT TO        → 250
//   DATA           → 354 → send headers + body → "." → 250
//   QUIT           → 221
// ================================================================

// Base64 encode for SMTP AUTH LOGIN.
// Handles arbitrary-length input; produces standard base64 output.
static const char _b64t[] =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

static String smtpB64(const String& s) {
    String out;
    int len = s.length();
    const uint8_t* b = (const uint8_t*)s.c_str();
    for (int i = 0; i < len; i += 3) {
        uint32_t v  = (uint32_t)b[i] << 16;
        if (i+1 < len) v |= (uint32_t)b[i+1] << 8;
        if (i+2 < len) v |= (uint32_t)b[i+2];
        out += _b64t[(v >> 18) & 0x3F];
        out += _b64t[(v >> 12) & 0x3F];
        out += (i+1 < len) ? _b64t[(v >> 6) & 0x3F] : '=';
        out += (i+2 < len) ? _b64t[v & 0x3F]        : '=';
    }
    return out;
}

// Read one SMTP response, correctly handling multi-line replies
// (e.g. EHLO returns multiple "250-..." lines before the final
// "250 " line). Returns the numeric code from the final line.
static int smtpRead(WiFiClientSecure& c) {
    int code = 0;
    unsigned long t = millis();
    while (millis() - t < 6000) {
        if (c.available()) {
            String line = c.readStringUntil('\n');
            line.trim();
            Serial.println("[SMTP] << " + line);
            code = line.substring(0, 3).toInt();
            // A space after the 3-digit code (not a dash) marks
            // the last line of a multi-line response.
            if (line.length() < 4 || line[3] != '-') break;
            t = millis();   // reset timeout between continuation lines
        }
        delay(5);
    }
    return code;
}

// Send one SMTP command and return true if the response matches expected.
static bool smtpCmd(WiFiClientSecure& c, const String& cmd, int expected) {
    Serial.println("[SMTP] >> " + cmd);
    c.println(cmd);
    int code = smtpRead(c);
    return code == expected;
}

// Send an alert email directly over SMTPS.
// Returns true on successful delivery (server accepted the message).
static bool sendSmtpEmail(const String& subject,
                          const String& textBody,
                          const String& htmlBody) {
    smtpTls.stop();         // ensure clean state from any prior attempt
    smtpTls.setInsecure();  // skip certificate verification (prototype)

    if (!smtpTls.connect(SMTP_HOST, SMTP_PORT)) {
        Serial.println("[SMTP] Connect failed.");
        return false;
    }

    if (smtpRead(smtpTls) != 220) {
        Serial.println("[SMTP] No 220 greeting.");
        smtpTls.stop();
        return false;
    }

    // EHLO — multi-line 250 response, smtpRead drains all lines
    if (!smtpCmd(smtpTls, "EHLO babymonitor", 250)) {
        // Some servers return 250 on the last line only;
        // a non-250 here is a genuine failure.
        Serial.println("[SMTP] EHLO failed.");
        smtpTls.stop();
        return false;
    }

    // AUTH LOGIN — server prompts for username then password, each
    // base64-encoded. 334 = "send next credential". 235 = auth OK.
    smtpTls.println("AUTH LOGIN");
    smtpRead(smtpTls);                              // 334
    smtpTls.println(smtpB64(SMTP_USERNAME));
    smtpRead(smtpTls);                              // 334
    smtpTls.println(smtpB64(SENDER_APP_PASSWORD));
    int authCode = smtpRead(smtpTls);               // 235 on success
    if (authCode != 235) {
        Serial.printf("[SMTP] AUTH failed (code %d).\n", authCode);
        smtpTls.stop();
        return false;
    }

    // Envelope
    if (!smtpCmd(smtpTls,
            String("MAIL FROM:<") + SENDER_EMAIL + ">", 250)) {
        smtpTls.stop(); return false;
    }
    if (!smtpCmd(smtpTls,
            String("RCPT TO:<") + RECIPIENT_EMAIL + ">", 250)) {
        smtpTls.stop(); return false;
    }

    // DATA — server returns 354 "start input", we send headers + body,
    // then terminate with a line containing only "."
    smtpTls.println("DATA");
    if (smtpRead(smtpTls) != 354) {
        Serial.println("[SMTP] DATA rejected.");
        smtpTls.stop();
        return false;
    }

    // RFC 5322 headers
    smtpTls.println("From: Baby Monitor <" + String(SENDER_EMAIL) + ">");
    smtpTls.println("To: " + String(RECIPIENT_NAME) +
                    " <" + String(RECIPIENT_EMAIL) + ">");
    smtpTls.println("Subject: Baby Monitor Alert: " + subject);
    smtpTls.println("MIME-Version: 1.0");
    smtpTls.println(
        "Content-Type: multipart/alternative; boundary=\"bnd_babymon\"");
    smtpTls.println();   // blank line separates headers from body

    // Plain-text MIME part
    smtpTls.println("--bnd_babymon");
    smtpTls.println("Content-Type: text/plain; charset=UTF-8");
    smtpTls.println();
    smtpTls.println(textBody);

    // HTML MIME part
    smtpTls.println("--bnd_babymon");
    smtpTls.println("Content-Type: text/html; charset=UTF-8");
    smtpTls.println();
    smtpTls.println(htmlBody);
    smtpTls.println("--bnd_babymon--");   // final boundary

    // End-of-message marker
    smtpTls.println(".");
    int dataCode = smtpRead(smtpTls);     // 250 = message accepted

    smtpCmd(smtpTls, "QUIT", 221);
    smtpTls.stop();

    if (dataCode == 250) {
        Serial.println("[SMTP] Email sent successfully.");
        return true;
    }
    Serial.printf("[SMTP] Message rejected (code %d).\n", dataCode);
    return false;
}

// ================================================================
