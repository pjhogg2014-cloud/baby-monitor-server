// ================================================================
// evaluateAlerts() — check all conditions against thresholds
// Each condition has its own cooldown timer
// ================================================================
void evaluateAlerts(float objectTemp) {
    unsigned long now = millis();

    // Only evaluate radar-based alerts after the initialisation grace period
    bool gracePeriodOver = (now > INIT_GRACE_PERIOD);

    // ---- Temperature alerts ----
    if (objectTemp > FEVER_THRESHOLD) {
        if (now - lastTempAlertTime >= ALERT_COOLDOWN) {
            sendAlert(objectTemp,
                "Fever detected: " + String(objectTemp, 1) + " C (threshold "
                + String(FEVER_THRESHOLD, 1) + " C)");
            lastTempAlertTime = now;
        } else {
            Serial.println("SUPPRESSED: Fever — cooldown active.");
        }
    } else if (objectTemp < HYPO_THRESHOLD && objectTemp > 20.0f) {
        if (now - lastTempAlertTime >= ALERT_COOLDOWN) {
            sendAlert(objectTemp,
                "Low temperature: " + String(objectTemp, 1) + " C (threshold "
                + String(HYPO_THRESHOLD, 1) + " C)");
            lastTempAlertTime = now;
        } else {
            Serial.println("SUPPRESSED: Hypothermia — cooldown active.");
        }
    }

    if (!gracePeriodOver) {
        Serial.println("Radar alerts suppressed — initialisation grace period.");
        return;
    }

    // ---- Apnea / no detection alert ----
    if (!radarDetected &&
        (now - lastDetectedTime >= NO_DETECT_TIMEOUT)) {
        if (now - lastApneaTime >= ALERT_COOLDOWN) {
            sendAlert(objectTemp,
                "Breathing not detected — possible apnea (no signal for "
                + String(NO_DETECT_TIMEOUT / 1000) + " seconds)");
            lastApneaTime = now;
        } else {
            Serial.println("SUPPRESSED: Apnea — cooldown active.");
        }
    }

    // ---- Breathing rate alerts (only if subject detected) ----
    if (radarDetected && currentBreathing > 0) {
        if (currentBreathing < BRADYPNOEA_THRESHOLD) {
            if (now - lastBradypnoeaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "Low breathing rate: " + String(currentBreathing, 0)
                    + " bpm (threshold " + String(BRADYPNOEA_THRESHOLD, 0) + " bpm)");
                lastBradypnoeaTime = now;
            } else {
                Serial.println("SUPPRESSED: Bradypnoea — cooldown active.");
            }
        } else if (currentBreathing > TACHYPNOEA_THRESHOLD) {
            if (now - lastTachypnoeaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "High breathing rate: " + String(currentBreathing, 0)
                    + " bpm (threshold " + String(TACHYPNOEA_THRESHOLD, 0) + " bpm)");
                lastTachypnoeaTime = now;
            } else {
                Serial.println("SUPPRESSED: Tachypnoea — cooldown active.");
            }
        }
    }

    // ---- Heart rate alerts (only if subject detected) ----
    if (radarDetected && currentHeartRate > 0) {
        if (currentHeartRate < BRADYCARDIA_THRESHOLD) {
            if (now - lastBradycardiaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "Low heart rate: " + String(currentHeartRate, 0)
                    + " bpm (threshold " + String(BRADYCARDIA_THRESHOLD, 0) + " bpm)");
                lastBradycardiaTime = now;
            } else {
                Serial.println("SUPPRESSED: Bradycardia — cooldown active.");
            }
        } else if (currentHeartRate > TACHYCARDIA_THRESHOLD) {
            if (now - lastTachycardiaTime >= ALERT_COOLDOWN) {
                sendAlert(objectTemp,
                    "High heart rate: " + String(currentHeartRate, 0)
                    + " bpm (threshold " + String(TACHYCARDIA_THRESHOLD, 0) + " bpm)");
                lastTachycardiaTime = now;
            } else {
                Serial.println("SUPPRESSED: Tachycardia — cooldown active.");
            }
        }
    }
}

// ================================================================
// publishSensorData() — publish all readings to MQTT dashboard
// ================================================================
void publishSensorData(float objectTemp, float ambientTemp) {
    char buf[256];

    // Temperature topic
    snprintf(buf, sizeof(buf),
        "{\"object\":%.1f,\"ambient\":%.1f,\"ts\":%lu}",
        objectTemp, ambientTemp, (unsigned long)time(nullptr));
    mqttClient.publish(TOPIC_TEMPERATURE, buf, false, 0);

    // Radar topic
    snprintf(buf, sizeof(buf),
        "{\"breathing\":%.0f,\"heartrate\":%.0f,"
        "\"distance\":%.2f,\"detected\":%s,\"ts\":%lu}",
        currentBreathing, currentHeartRate, currentDistance,
        radarDetected ? "true" : "false",
        (unsigned long)time(nullptr));
    mqttClient.publish(TOPIC_RADAR, buf, false, 0);

    Serial.printf("MQTT published — Temp: %.1f C | BR: %.0f bpm | HR: %.0f bpm | "
                  "Detected: %s\n",
                  objectTemp, currentBreathing, currentHeartRate,
                  radarDetected ? "Yes" : "No");
}

// ================================================================
// setup()
// ================================================================
void setup() {
    Serial.begin(115200);

    // ---- I2C for MLX90614 ----
    Wire.begin(I2C_SDA, I2C_SCL);
    if (!mlx.begin()) {
        Serial.println("ERROR: MLX90614 not found — check wiring.");
        while (true) delay(1000);
    }
    Serial.println("MLX90614 ready.");

    // ---- Radar UART ----
    mmWaveSerial.begin(115200, SERIAL_8N1, RADAR_RX, RADAR_TX);
    mmWave.begin(&mmWaveSerial);
    Serial.println("MR60BHA2 radar initialised.");
    lastDetectedTime = millis(); // start the no-detect timer from boot

    // ---- I2S microphone ----
    setupI2S();

    // ---- Wi-Fi ----
    Serial.printf("Connecting to %s", WIFI_SSID);
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
    }
    Serial.printf("\nConnected. IP: %s\n", WiFi.localIP().toString().c_str());

    // ---- NTP time sync ----
    // Change first arg to 3600 during BST (March-October), 0 for GMT
    configTime(3600, 0, "pool.ntp.org", "time.nist.gov");
    Serial.print("Syncing NTP time");
    time_t now = time(nullptr);
    while (now < 100000) {
        delay(200);
        Serial.print(".");
        now = time(nullptr);
    }
    Serial.println("\nTime synced.");

    // ---- MQTT (non-blocking, runs in background FreeRTOS task) ----
    mqttClient.setURI(MQTT_URI, MQTT_USER, MQTT_PASS);
    mqttClient.setInsecure();           // skip cert verify for prototype
    mqttClient.enableLastWillMessage(TOPIC_STATUS, "offline", true);
    mqttClient.loopStart();             // returns immediately
    Serial.println("MQTT connecting in background...");

    // ---- Audio WebSocket ----
    audioConnected = connectAudio();

    Serial.println("System ready — monitoring started.");
}

// ================================================================
// loop()
// ================================================================
void loop() {
    unsigned long now = millis();

    // ---- Stream audio continuously ----
    if (audioConnected && audioTls.connected()) {
        int16_t audioBuf[AUDIO_BUF_LEN];
        size_t bytesRead = 0;
        i2s_read(I2S_NUM_0, audioBuf, sizeof(audioBuf), &bytesRead, 0);
        if (bytesRead > 0) {
            sendAudioFrame((uint8_t*)audioBuf, bytesRead);
        }
    } else if (!audioConnected || !audioTls.connected()) {
        // Attempt reconnect every 10 seconds
        static unsigned long lastAudioRetry = 0;
        if (now - lastAudioRetry > 10000) {
            Serial.println("Reconnecting audio WebSocket...");
            audioConnected = connectAudio();
            lastAudioRetry = now;
        }
    }

    // ---- Poll radar continuously ----
    updateRadar();

    // ---- Sensor reading and alert evaluation on interval ----
    if (now - lastReadTime < READING_INTERVAL) return;
    lastReadTime = now;

    // Read MLX90614
    float objectTemp  = mlx.readObjectTempC();
    float ambientTemp = mlx.readAmbientTempC();

    Serial.print("MLX90614 Object Temp: ");
    Serial.print(objectTemp, 1);
    Serial.println(" C");

    Serial.printf("[%.0fs] Object: %.1f C | Ambient: %.1f C\n",
                  now / 1000.0, objectTemp, ambientTemp);

    // Validate reading — catches NaN and out-of-range values
    if (isnan(objectTemp) || isnan(ambientTemp) ||
        objectTemp > 50.0f || objectTemp < 20.0f) {
        Serial.println("WARNING: Invalid temperature reading — skipping.");
        return;
    }

    // Publish all sensor data to MQTT dashboard
    publishSensorData(objectTemp, ambientTemp);

    // Evaluate all alert conditions
    evaluateAlerts(objectTemp);
}
