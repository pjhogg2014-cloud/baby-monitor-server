// ================================================================
// I2S microphone setup
// ================================================================
void setupI2S() {
    i2s_config_t i2s_config = {
        .mode                 = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
        .sample_rate          = SAMPLE_RATE,
        .bits_per_sample      = I2S_BITS_PER_SAMPLE_16BIT,
        .channel_format       = I2S_CHANNEL_FMT_ONLY_LEFT,
        .communication_format = I2S_COMM_FORMAT_STAND_I2S,
        .intr_alloc_flags     = ESP_INTR_FLAG_LEVEL1,
        .dma_buf_count        = 4,
        .dma_buf_len          = AUDIO_BUF_LEN,
        .use_apll             = false,
        .tx_desc_auto_clear   = false,
        .fixed_mclk           = 0
    };
    i2s_pin_config_t pin_config = {
        .bck_io_num   = I2S_SCK,
        .ws_io_num    = I2S_WS,
        .data_out_num = I2S_PIN_NO_CHANGE,
        .data_in_num  = I2S_SD
    };
    i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
    i2s_set_pin(I2S_NUM_0, &pin_config);
    Serial.println("I2S microphone ready.");
}

// ================================================================
// Audio WebSocket — connect to Render server
// ================================================================
bool connectAudio() {
    audioTls.setInsecure();
    if (!audioTls.connect(AUDIO_SERVER_HOST, AUDIO_SERVER_PORT)) {
        Serial.println("Audio server connect failed.");
        return false;
    }
    audioTls.printf(
        "GET %s HTTP/1.1\r\n"
        "Host: %s\r\n"
        "Upgrade: websocket\r\n"
        "Connection: Upgrade\r\n"
        "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
        "Sec-WebSocket-Version: 13\r\n"
        "\r\n",
        AUDIO_SERVER_PATH, AUDIO_SERVER_HOST
    );
    String response = "";
    unsigned long t = millis();
    while (millis() - t < 3000) {
        if (audioTls.available()) {
            String line = audioTls.readStringUntil('\n');
            response += line;
            if (line == "\r") break;
        }
    }
    if (response.indexOf("101") > 0) {
        Serial.println("Audio WebSocket connected.");
        return true;
    }
    Serial.println("Audio WebSocket handshake failed.");
    return false;
}

// ================================================================
// Send one WebSocket binary frame to audio server
// ================================================================
void sendAudioFrame(uint8_t* data, size_t len) {
    if (!audioTls.connected()) return;
    uint8_t header[4];
    header[0] = 0x82;           // FIN bit + binary opcode
    if (len <= 125) {
        header[1] = (uint8_t)len;
        audioTls.write(header, 2);
    } else {
        header[1] = 126;
        header[2] = (len >> 8) & 0xFF;
        header[3] = len & 0xFF;
        audioTls.write(header, 4);
    }
    audioTls.write(data, len);
}

// ================================================================
// updateRadar() — poll MR60BHA2 via Seeed library
// Updates global currentBreathing, currentHeartRate,
// currentDistance, radarDetected
// ================================================================
void updateRadar() {
    if (mmWave.update(100)) {
        radarDetected    = true;
        lastDetectedTime = millis();

        float breath_rate;
        if (mmWave.getBreathRate(breath_rate)) {
            currentBreathing = breath_rate;
            Serial.printf("Breath rate : %.2f bpm\n", currentBreathing);
        }

        float heart_rate;
        if (mmWave.getHeartRate(heart_rate)) {
            currentHeartRate = heart_rate;
            Serial.printf("Heart rate  : %.2f bpm\n", currentHeartRate);
        }

        float distance;
        if (mmWave.getDistance(distance)) {
            currentDistance = distance;
            Serial.printf("Distance    : %.2f m\n", currentDistance);
        }

        // Optional — print phase data for diagnostics
        float total_phase, breath_phase, heart_phase;
        if (mmWave.getHeartBreathPhases(total_phase, breath_phase, heart_phase)) {
            Serial.printf("Phases — total: %.2f  breath: %.2f  heart: %.2f\n",
                          total_phase, breath_phase, heart_phase);
        }

    } else {
        radarDetected = false;
    }
}

// ================================================================
// SMTP alert — sends email and publishes alert to MQTT
// condition: human-readable description of the alert
// ================================================================
void smtpCallback(SMTPStatus status) {
    Serial.println(status.text);
}

void sendAlert(float objectTemp, String condition) {
    Serial.println("Alert triggered: " + condition);

    // Build MQTT alert payload
    char alertBuf[256];
    snprintf(alertBuf, sizeof(alertBuf),
        "{\"condition\":\"%s\","
        "\"temperature\":%.1f,"
        "\"breathing\":%.0f,"
        "\"heartrate\":%.0f,"
        "\"detected\":%s,"
        "\"ts\":%lu}",
        condition.c_str(),
        objectTemp,
        currentBreathing,
        currentHeartRate,
        radarDetected ? "true" : "false",
        (unsigned long)time(nullptr)
    );
    mqttClient.publish(TOPIC_ALERT, alertBuf, false, 1);

    // Send SMTP email
    smtp.connect(SMTP_HOST, SMTP_PORT, smtpCallback);
    if (!smtp.isConnected()) {
        Serial.println("SMTP connect failed — alert email not sent.");
        return;
    }
    smtp.authenticate(SMTP_USERNAME, SENDER_APP_PASSWORD, readymail_auth_password);

    SMTPMessage msg;
    msg.headers.add(rfc822_from,
        String("Baby Monitor <") + SENDER_EMAIL + ">");
    msg.headers.add(rfc822_to,
        String(RECIPIENT_NAME) + " <" + RECIPIENT_EMAIL + ">");
    msg.headers.add(rfc822_subject,
        "Baby Monitor Alert: " + condition);
    msg.timestamp = time(nullptr);

    // Plain text body
    String textBody =
        "Baby Monitor Alert\n\n"
        "Condition       : " + condition + "\n"
        "Temperature     : " + String(objectTemp, 1) + " C\n"
        "Breathing rate  : " + String(currentBreathing, 0) + " bpm\n"
        "Heart rate      : " + String(currentHeartRate, 0) + " bpm\n"
        "Subject detected: " + String(radarDetected ? "Yes" : "No") + "\n"
        "Distance        : " + String(currentDistance, 2) + " m\n\n"
        "Please check on the infant.\n\n"
        "Note: each alert condition is suppressed for 5 minutes after firing.\n"
        "-- Baby Monitor System";
    msg.text.body(textBody);

    // HTML body
    String htmlBody =
        "<html><body style='font-family:sans-serif;max-width:520px;'>"
        "<h2 style='color:#c0392b;'>Baby Monitor Alert</h2>"
        "<p><strong>" + condition + "</strong></p>"
        "<table style='border-collapse:collapse;width:100%;'>"

        "<tr style='background:#f8f8f8;'>"
        "<td style='padding:8px 12px;font-weight:bold;'>Temperature</td>"
        "<td style='padding:8px 12px;color:#c0392b;font-size:18px;'>"
        + String(objectTemp, 1) + " &deg;C</td></tr>"

        "<tr>"
        "<td style='padding:8px 12px;font-weight:bold;'>Breathing rate</td>"
        "<td style='padding:8px 12px;'>" + String(currentBreathing, 0) + " bpm</td></tr>"

        "<tr style='background:#f8f8f8;'>"
        "<td style='padding:8px 12px;font-weight:bold;'>Heart rate</td>"
        "<td style='padding:8px 12px;'>" + String(currentHeartRate, 0) + " bpm</td></tr>"

        "<tr>"
        "<td style='padding:8px 12px;font-weight:bold;'>Subject detected</td>"
        "<td style='padding:8px 12px;'>"
        + String(radarDetected ? "Yes" : "No") + "</td></tr>"

        "<tr style='background:#f8f8f8;'>"
        "<td style='padding:8px 12px;font-weight:bold;'>Distance</td>"
        "<td style='padding:8px 12px;'>" + String(currentDistance, 2) + " m</td></tr>"

        "</table>"
        "<p style='margin-top:20px;font-size:15px;'>"
        "<strong>Please check on the infant.</strong></p>"
        "<p style='color:#aaa;font-size:11px;'>"
        "Each alert condition is suppressed for 5 minutes after firing.</p>"
