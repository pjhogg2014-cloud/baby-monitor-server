<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Baby Vital Monitor</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #0f1923;
    color: #e8edf2;
    min-height: 100vh;
    padding: 20px;
  }
  h1 {
    text-align: center;
    font-size: 1.4rem;
    color: #7ecfff;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 20px;
  }
  .card {
    background: #1a2635;
    border-radius: 10px;
    padding: 16px 14px 14px;
    text-align: center;
    border: 1px solid #263545;
  }
  .card .label { font-size: 0.75rem; color: #7a9bb5; text-transform: uppercase; letter-spacing: 0.08em; }
  .card .value { font-size: 2rem; font-weight: 700; margin: 6px 0 2px; color: #e8edf2; }
  .card .unit  { font-size: 0.7rem; color: #5a7a95; }
  .card.alert-active { border-color: #e74c3c; background: #2a1a1a; }
  .card.alert-active .value { color: #e74c3c; }

  .media-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 20px;
  }
  @media (max-width: 640px) { .media-row { grid-template-columns: 1fr; } }

  .panel {
    background: #1a2635;
    border-radius: 10px;
    border: 1px solid #263545;
    overflow: hidden;
  }
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    font-size: 0.8rem;
    color: #7a9bb5;
    border-bottom: 1px solid #263545;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #2c3e50; display: inline-block; margin-right: 6px;
  }
  .dot.connected { background: #2ecc71; }
  .dot.error     { background: #e74c3c; }

  #videoFeed {
    width: 100%; display: block;
    background: #0a1018;
    aspect-ratio: 4/3;
    object-fit: contain;
  }

  .audio-panel { padding: 14px; }
  .audio-vis {
    width: 100%; height: 60px;
    background: #0f1923;
    border-radius: 6px;
    margin-bottom: 10px;
  }
  #audioToggle {
    width: 100%;
    padding: 8px;
    background: #7ecfff;
    color: #0f1923;
    border: none;
    border-radius: 6px;
    font-weight: 700;
    cursor: pointer;
    font-size: 0.85rem;
  }
  #audioToggle:hover { background: #5bbff0; }
  #audioToggle.muted { background: #2c3e50; color: #7a9bb5; }

  .alerts-panel {
    background: #1a2635;
    border-radius: 10px;
    border: 1px solid #263545;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .alerts-header {
    padding: 10px 14px;
    font-size: 0.8rem;
    color: #7a9bb5;
    border-bottom: 1px solid #263545;
  }
  #alertList {
    list-style: none;
    max-height: 160px;
    overflow-y: auto;
    padding: 0;
  }
  #alertList li {
    padding: 8px 14px;
    font-size: 0.8rem;
    border-bottom: 1px solid #152030;
    color: #e8edf2;
  }
  #alertList li:first-child { color: #e74c3c; font-weight: 600; }
  .ts { color: #5a7a95; margin-right: 8px; font-size: 0.75rem; }

  .status-bar {
    display: flex; gap: 10px; flex-wrap: wrap;
    font-size: 0.72rem; color: #5a7a95;
    justify-content: center;
  }
  .status-bar span { display: flex; align-items: center; gap: 4px; }
</style>
</head>
<body>

<h1>🍼 Baby Vital Monitor</h1>

<!-- Sensor cards -->
<div class="grid">
  <div class="card" id="card-temp">
    <div class="label">Temperature</div>
    <div class="value" id="val-temp">--.-</div>
    <div class="unit">°C</div>
  </div>
  <div class="card" id="card-br">
    <div class="label">Breathing Rate</div>
    <div class="value" id="val-br">--</div>
    <div class="unit">breaths / min</div>
  </div>
  <div class="card" id="card-hr">
    <div class="label">Heart Rate</div>
    <div class="value" id="val-hr">--</div>
    <div class="unit">beats / min</div>
  </div>
  <div class="card" id="card-dist">
    <div class="label">Radar Distance</div>
    <div class="value" id="val-dist">--.-</div>
    <div class="unit">metres</div>
  </div>
</div>

<!-- Video + Audio -->
<div class="media-row">

  <div class="panel">
    <div class="panel-header">
      <span><span class="dot" id="vidDot"></span>Camera</span>
      <span id="vidStatus">connecting…</span>
    </div>
    <img id="videoFeed" alt="Camera feed" />
  </div>

  <div class="panel">
    <div class="panel-header">
      <span><span class="dot" id="audDot"></span>Microphone</span>
      <span id="audStatus">connecting…</span>
    </div>
    <div class="audio-panel">
      <canvas class="audio-vis" id="audioCanvas"></canvas>
      <button id="audioToggle" onclick="toggleAudio()">🔊 Audio ON</button>
    </div>
  </div>

</div>

<!-- Alert feed -->
<div class="alerts-panel">
  <div class="alerts-header">⚠ Alert Feed</div>
  <ul id="alertList">
    <li style="color:#5a7a95;padding:10px 14px;font-size:0.8rem;">No alerts yet.</li>
  </ul>
</div>

<!-- Connection status bar -->
<div class="status-bar">
  <span><span class="dot" id="mqttDot"></span>MQTT Dashboard</span>
  <span><span class="dot" id="audioDot2"></span>Audio Stream</span>
  <span><span class="dot" id="videoDot2"></span>Video Stream</span>
</div>

<script>
// ================================================================
// Configuration — update SERVER to your Render deployment URL
// ================================================================
const SERVER = 'wss://baby-monitor-server-0st8.onrender.com';

// ================================================================
// MQTT / sensor data (existing dashboard WebSocket)
// ================================================================
let dashWs = null;

function connectDash() {
    dashWs = new WebSocket(SERVER + '/dashboard');
    dashWs.onopen  = () => setDot('mqttDot', 'connected');
    dashWs.onclose = () => { setDot('mqttDot', ''); setTimeout(connectDash, 4000); };
    dashWs.onmessage = (e) => {
        try {
            const d = JSON.parse(e.data);
            if (d.object   !== undefined) updateTemp(d.object);
            if (d.breathing !== undefined) document.getElementById('val-br').textContent   = Math.round(d.breathing);
            if (d.heartrate !== undefined) document.getElementById('val-hr').textContent   = Math.round(d.heartrate);
            if (d.distance  !== undefined) document.getElementById('val-dist').textContent = d.distance.toFixed(2);
            if (d.condition) addAlert(d.condition, d.ts);
        } catch {}
    };
}

function updateTemp(t) {
    const el = document.getElementById('val-temp');
    el.textContent = t.toFixed(1);
    const card = document.getElementById('card-temp');
    card.classList.toggle('alert-active', t >= 38.0 || t < 34.0);
}

function addAlert(condition, ts) {
    const list = document.getElementById('alertList');
    // Remove placeholder if present
    if (list.children.length === 1 && list.children[0].style.color === 'rgb(90, 122, 149)')
        list.innerHTML = '';
    const li = document.createElement('li');
    const time = ts ? new Date(ts * 1000).toLocaleTimeString() : new Date().toLocaleTimeString();
    li.innerHTML = `<span class="ts">${time}</span>${condition}`;
    list.prepend(li);
    // Keep last 20 alerts
    while (list.children.length > 20) list.removeChild(list.lastChild);
}

// ================================================================
// VIDEO WebSocket
// Receives binary JPEG frames and renders them to an <img> element.
// Each message = one complete JPEG — no reassembly needed.
// ================================================================
let videoWs  = null;
let videoImg = document.getElementById('videoFeed');

function connectVideo() {
    videoWs = new WebSocket(SERVER + '/video');
    videoWs.binaryType = 'arraybuffer';

    videoWs.onopen = () => {
        setDot('vidDot',    'connected');
        setDot('videoDot2', 'connected');
        document.getElementById('vidStatus').textContent = 'live';
    };
    videoWs.onclose = () => {
        setDot('vidDot',    'error');
        setDot('videoDot2', '');
        document.getElementById('vidStatus').textContent = 'reconnecting…';
        setTimeout(connectVideo, 4000);
    };
    videoWs.onmessage = (event) => {
        // Revoke previous object URL to prevent memory leak,
        // then create a new one from the incoming JPEG bytes.
        const prev = videoImg.src;
        const blob = new Blob([event.data], { type: 'image/jpeg' });
        videoImg.src = URL.createObjectURL(blob);
        if (prev && prev.startsWith('blob:')) URL.revokeObjectURL(prev);
    };
}

// ================================================================
// AUDIO WebSocket
// Receives raw 16-bit PCM frames at 16 kHz, plays them via the
// Web Audio API. User must interact with the page first (browser
// autoplay policy requires a user gesture before AudioContext
// can produce sound — the toggle button serves this purpose).
// ================================================================
let audioWs      = null;
let audioCtx     = null;
let nextPlayTime = 0;
let audioMuted   = false;

// Waveform visualiser
const canvas    = document.getElementById('audioCanvas');
const canvasCtx = canvas.getContext('2d');
const BAR_COUNT = 48;
let   bars      = new Array(BAR_COUNT).fill(0);

function drawBars() {
    requestAnimationFrame(drawBars);
    const W = canvas.clientWidth, H = canvas.clientHeight;
    if (canvas.width !== W || canvas.height !== H) {
        canvas.width = W; canvas.height = H;
    }
    canvasCtx.clearRect(0, 0, W, H);
    const bw = (W - (BAR_COUNT - 1)) / BAR_COUNT;
    bars.forEach((v, i) => {
        const h = Math.max(2, v * H);
        canvasCtx.fillStyle = audioMuted ? '#2c3e50' : '#7ecfff';
        canvasCtx.fillRect(i * (bw + 1), H - h, bw, h);
    });
    // Decay bars slowly
    bars = bars.map(v => v * 0.85);
}
drawBars();

function updateBars(pcmData) {
    const chunk = Math.floor(pcmData.length / BAR_COUNT);
    for (let b = 0; b < BAR_COUNT; b++) {
        let sum = 0;
        for (let i = 0; i < chunk; i++) {
            sum += Math.abs(pcmData[b * chunk + i]);
        }
        bars[b] = Math.max(bars[b], (sum / chunk) / 32768);
    }
}

function connectAudio() {
    audioWs = new WebSocket(SERVER + '/audio');
    audioWs.binaryType = 'arraybuffer';

    audioWs.onopen = () => {
        setDot('audDot',    'connected');
        setDot('audioDot2', 'connected');
        document.getElementById('audStatus').textContent = 'live';
    };
    audioWs.onclose = () => {
        setDot('audDot',    'error');
        setDot('audioDot2', '');
        document.getElementById('audStatus').textContent = 'reconnecting…';
        setTimeout(connectAudio, 4000);
    };
    audioWs.onmessage = (event) => {
        const int16 = new Int16Array(event.data);
        updateBars(int16);   // always update visualiser, even when muted

        if (audioMuted || !audioCtx) return;

        // Convert Int16 PCM → Float32 (Web Audio API requires Float32)
        const float32 = new Float32Array(int16.length);
        for (let i = 0; i < int16.length; i++) {
            float32[i] = int16[i] / 32768.0;
        }

        const buffer = audioCtx.createBuffer(1, float32.length, 16000);
        buffer.copyToChannel(float32, 0);

        const source = audioCtx.createBufferSource();
        source.buffer = buffer;
        source.connect(audioCtx.destination);

        // Schedule seamless playback — schedule slightly ahead to
        // absorb network jitter without audible gaps.
        const now = audioCtx.currentTime;
        if (nextPlayTime < now + 0.01) nextPlayTime = now + 0.05;
        source.start(nextPlayTime);
        nextPlayTime += buffer.duration;
    };
}

function toggleAudio() {
    const btn = document.getElementById('audioToggle');
    if (!audioCtx) {
        // First click: create AudioContext (satisfies browser autoplay policy)
        audioCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 16000 });
    }
    audioMuted = !audioMuted;
    btn.textContent = audioMuted ? '🔇 Audio OFF' : '🔊 Audio ON';
    btn.classList.toggle('muted', audioMuted);
}

// ================================================================
// Helpers
// ================================================================
function setDot(id, state) {
    const el = document.getElementById(id);
    el.className = 'dot' + (state ? ' ' + state : '');
}

// ================================================================
// Start everything
// ================================================================
connectDash();
connectVideo();
connectAudio();
</script>
</body>
</html>
