<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Baby Monitor — Live Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0e14;
  --surface:#111620;
  --surface2:#1a2030;
  --border:#1e2a3a;
  --accent:#00c2ff;
  --accent2:#00ff9d;
  --warn:#ffb020;
  --danger:#ff4560;
  --text:#e2eaf4;
  --muted:#5a7080;
  --mono:'DM Mono',monospace;
  --sans:'Syne',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:13px;min-height:100vh}

/* topbar */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 24px;border-bottom:1px solid var(--border);
  background:var(--surface);position:sticky;top:0;z-index:10;
}
.topbar-title{font-size:15px;font-weight:700;letter-spacing:0.04em}
.topbar-sub{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:2px}
.topbar-right{display:flex;align-items:center;gap:14px}
.time{font-family:var(--mono);font-size:12px;color:var(--muted)}
.status-pill{
  display:flex;align-items:center;gap:7px;
  border-radius:20px;padding:5px 12px;font-family:var(--mono);font-size:11px;
  background:#0d1f14;border:1px solid #1a3d2a;color:var(--accent2);
  transition:all .3s;
}
.status-pill.offline{background:#1f0a0a;border-color:#3d0a0a;color:var(--danger)}
.pulse{width:7px;height:7px;border-radius:50%;background:var(--accent2);animation:pulse 1.8s ease-in-out infinite}
.pulse.offline{background:var(--danger);animation:none}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,157,.5)}50%{opacity:.7;box-shadow:0 0 0 5px rgba(0,255,157,0)}}

/* main grid */
.main{padding:20px 24px;display:grid;grid-template-columns:1fr 1fr 1fr;grid-template-rows:auto auto auto;gap:14px}

/* metric cards */
.metric-card{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:18px 20px;position:relative;overflow:hidden;
}
.metric-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--card-accent,var(--accent)),transparent);
}
.metric-card.ok{--card-accent:var(--accent2)}
.metric-card.warn{--card-accent:var(--warn)}
.metric-card.alert{--card-accent:var(--danger)}
.metric-label{font-size:10px;font-family:var(--mono);color:var(--muted);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px}
.metric-value{font-size:38px;font-weight:800;letter-spacing:-0.02em;line-height:1;transition:color .3s}
.metric-unit{font-size:14px;font-weight:400;color:var(--muted);margin-left:4px}
.metric-sub{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:8px;display:flex;align-items:center;gap:5px}
.badge{padding:2px 8px;border-radius:4px;font-size:9px;font-family:var(--mono);font-weight:500;letter-spacing:0.08em;transition:all .3s}
.badge.ok{background:#0d1f14;color:var(--accent2);border:1px solid #1a3d2a}
.badge.warn{background:#1f160a;color:var(--warn);border:1px solid #3d2e0a}
.badge.alert{background:#1f0a0a;color:var(--danger);border:1px solid #3d0a0a}
.badge.neutral{background:var(--surface2);color:var(--muted);border:1px solid var(--border)}

/* chart cards */
.chart-card{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:18px 20px;
}
.chart-card.span2{grid-column:span 2}
.chart-card.span3{grid-column:span 3}
.chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.chart-title{font-size:11px;font-weight:600;letter-spacing:0.08em;color:var(--text);font-family:var(--mono)}
.chart-wrap{position:relative;height:120px}

/* alert feed */
.alert-card{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:18px 20px;grid-column:1;
}
.alert-list{display:flex;flex-direction:column;gap:8px;margin-top:12px;max-height:180px;overflow-y:auto}
.alert-item{
  display:flex;align-items:flex-start;gap:10px;padding:10px 12px;
  background:var(--surface2);border-radius:7px;border-left:3px solid transparent;
  animation:fadeIn .3s ease;
}
@keyframes fadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:none}}
.alert-item.warn{border-color:var(--warn)}
.alert-item.info{border-color:var(--accent)}
.alert-item.ok{border-color:var(--accent2)}
.alert-dot{width:6px;height:6px;border-radius:50%;margin-top:3px;flex-shrink:0}
.alert-dot.warn{background:var(--warn)}
.alert-dot.info{background:var(--accent)}
.alert-dot.ok{background:var(--accent2)}
.alert-text{font-size:11px;color:var(--text);line-height:1.5}
.alert-time{font-family:var(--mono);font-size:9px;color:var(--muted);margin-top:2px}
.no-alerts{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:12px}

/* radar card */
.radar-card{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:18px 20px;grid-column:span 2;
}
.radar-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:12px}
.radar-stat{background:var(--surface2);border-radius:7px;padding:12px 14px}
.radar-stat-label{font-size:9px;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:6px}
.radar-stat-value{font-size:22px;font-weight:700;font-family:var(--sans)}
.radar-stat-bar{height:3px;background:var(--border);border-radius:2px;margin-top:8px}
.radar-stat-bar-fill{height:100%;border-radius:2px;transition:width .6s ease}

/* dist ring */
.dist-ring{
  display:flex;align-items:center;justify-content:center;
  width:54px;height:54px;border-radius:50%;
  border:2px solid var(--accent);font-family:var(--mono);font-size:10px;
  color:var(--accent);flex-shrink:0;
}

/* audio btn */
#audioBtn{
  background:var(--accent);color:#000;border:none;padding:8px 16px;
  border-radius:6px;cursor:pointer;font-size:12px;font-family:var(--mono);
  font-weight:500;letter-spacing:0.05em;transition:opacity .2s;
}
#audioBtn:hover{opacity:.85}

.section-label{
  grid-column:span 3;font-size:9px;font-family:var(--mono);color:var(--muted);
  letter-spacing:0.15em;text-transform:uppercase;padding:4px 0 0;
}
</style>
</head>
<body>

<div class="topbar">
  <div>
    <div class="topbar-title">🍼 Baby Monitor — Live Dashboard</div>
    <div class="topbar-sub">Freenove ESP32-S3 · MR60BHA2 60GHz · MLX90614 · INMP441</div>
  </div>
  <div class="topbar-right">
    <div class="status-pill offline" id="statusPill">
      <span class="pulse offline" id="pulseDot"></span>
      <span id="statusText">Connecting...</span>
    </div>
    <div class="time" id="clock">--:--:--</div>
  </div>
</div>

<div class="main">

  <div class="section-label">— Vital signs</div>

  <!-- Temperature -->
  <div class="metric-card ok" id="tempCard">
    <div class="metric-label">Skin Temperature</div>
    <div class="metric-value" style="color:var(--accent2)" id="tempVal">--<span class="metric-unit">°C</span></div>
    <div class="metric-sub">
      <span class="badge neutral" id="tempBadge">Waiting...</span>
      <span>fever threshold 38.0 °C</span>
    </div>
  </div>

  <!-- Breathing -->
  <div class="metric-card ok" id="brCard">
    <div class="metric-label">Breathing Rate</div>
    <div class="metric-value" style="color:var(--accent2)" id="brVal">--<span class="metric-unit">bpm</span></div>
    <div class="metric-sub">
      <span class="badge neutral" id="brBadge">Waiting...</span>
      <span>adult range 12–25 bpm</span>
    </div>
  </div>

  <!-- Heart rate -->
  <div class="metric-card ok" id="hrCard">
    <div class="metric-label">Heart Rate</div>
    <div class="metric-value" style="color:var(--accent)" id="hrVal">--<span class="metric-unit">bpm</span></div>
    <div class="metric-sub">
      <span class="badge neutral" id="hrBadge">Waiting...</span>
      <span>range 100–160 bpm</span>
    </div>
  </div>

  <!-- Temp chart -->
  <div class="chart-card">
    <div class="chart-header">
      <div class="chart-title">TEMPERATURE — ROLLING</div>
    </div>
    <div class="chart-wrap"><canvas id="tempChart"></canvas></div>
  </div>

  <!-- BR/HR chart -->
  <div class="chart-card span2">
    <div class="chart-header">
      <div class="chart-title">BREATHING &amp; HEART RATE — ROLLING</div>
    </div>
    <div class="chart-wrap"><canvas id="brhrChart"></canvas></div>
  </div>

  <!-- Alerts -->
  <div class="alert-card">
    <div class="chart-title">ALERT FEED</div>
    <div id="alertList"><p class="no-alerts">No alerts yet.</p></div>
  </div>

  <!-- Radar detail -->
  <div class="radar-card">
    <div style="display:flex;align-items:center;justify-content:space-between">
      <div class="chart-title">RADAR — MR60BHA2 · 60 GHz FMCW</div>
      <div style="display:flex;align-items:center;gap:10px">
        <div class="dist-ring" id="distVal">-- m</div>
        <div>
          <div style="font-size:9px;font-family:var(--mono);color:var(--muted)">DISTANCE</div>
          <div style="font-size:9px;color:var(--accent);font-family:var(--mono);margin-top:2px" id="detectLabel">--</div>
        </div>
      </div>
    </div>
    <div class="radar-grid">
      <div class="radar-stat">
        <div class="radar-stat-label">Breathing rate</div>
        <div class="radar-stat-value" style="color:var(--accent2)" id="radarBr">-- bpm</div>
        <div class="radar-stat-bar"><div class="radar-stat-bar-fill" id="brBar" style="width:0%;background:var(--accent2)"></div></div>
      </div>
      <div class="radar-stat">
        <div class="radar-stat-label">Heart rate</div>
        <div class="radar-stat-value" style="color:var(--accent)" id="radarHr">-- bpm</div>
        <div class="radar-stat-bar"><div class="radar-stat-bar-fill" id="hrBar" style="width:0%;background:var(--accent)"></div></div>
      </div>
    </div>
  </div>

  <!-- Audio -->
  <div class="chart-card" style="grid-column:3;grid-row:3">
    <div class="chart-header">
      <div class="chart-title">AUDIO — INMP441</div>
      <button id="audioBtn" onclick="startAudio()">▶ Listen</button>
    </div>
    <div class="chart-wrap"><canvas id="audioChart"></canvas></div>
  </div>

</div>

<script>
// ---- Clock ----
function updateClock(){
  document.getElementById('clock').textContent =
    new Date().toLocaleTimeString('en-GB',{hour12:false});
}
setInterval(updateClock,1000); updateClock();

// ---- Chart factory ----
function makeChart(id, datasets){
  return new Chart(document.getElementById(id),{
    type:'line',
    data:{labels:[], datasets},
    options:{
      animation:false, responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:datasets.length>1,labels:{color:'#5a7080',font:{family:'DM Mono',size:9},boxWidth:10}}},
      scales:{
        x:{display:false},
        y:{ticks:{font:{family:'DM Mono',size:9},color:'#5a7080',maxTicksLimit:4},grid:{color:'#1a2030'}}
      }
    }
  });
}

const tempChart = makeChart('tempChart',[
  {label:'Temp °C',data:[],borderColor:'#ffb020',borderWidth:1.5,
   backgroundColor:'rgba(255,176,32,0.07)',fill:true,tension:0.4,pointRadius:0}
]);
const brhrChart = makeChart('brhrChart',[
  {label:'Breathing bpm',data:[],borderColor:'#00ff9d',borderWidth:1.5,
   backgroundColor:'rgba(0,255,157,0.05)',fill:false,tension:0.4,pointRadius:0},
  {label:'Heart rate bpm',data:[],borderColor:'#00c2ff',borderWidth:1.5,
   backgroundColor:'rgba(0,194,255,0.05)',fill:false,tension:0.4,pointRadius:0}
]);
const audioChart = makeChart('audioChart',[
  {label:'Waveform',data:[],borderColor:'#9b59b6',borderWidth:1,
   fill:false,tension:0,pointRadius:0}
]);

function addPoint(chart, dsIndex, value){
  const t = new Date().toLocaleTimeString('en-GB',{hour12:false});
  if(dsIndex===0) chart.data.labels.push(t);
  chart.data.datasets[dsIndex].data.push(value);
  if(chart.data.labels.length>60){
    if(dsIndex===0) chart.data.labels.shift();
    chart.data.datasets[dsIndex].data.shift();
  }
  chart.update('none');
}

// ---- Status helpers ----
function setConnected(connected){
  const pill = document.getElementById('statusPill');
  const dot  = document.getElementById('pulseDot');
  const txt  = document.getElementById('statusText');
  if(connected){
    pill.classList.remove('offline');
    dot.classList.remove('offline');
    txt.textContent = 'Monitoring active';
  } else {
    pill.classList.add('offline');
    dot.classList.add('offline');
    txt.textContent = 'Disconnected — refresh to reconnect';
  }
}

function tempStatus(v){
  if(v>=38.0) return {cls:'alert',text:'Fever'};
  if(v<36.0)  return {cls:'warn', text:'Low temp'};
  return {cls:'ok',text:'Normal'};
}
function brStatus(v){
  if(v<12) return {cls:'warn',text:'Low'};
  if(v>25) return {cls:'warn',text:'High'};
  return {cls:'ok',text:'Normal'};
}
function hrStatus(v){
  if(v<100) return {cls:'warn',text:'Low'};
  if(v>160) return {cls:'alert',text:'High'};
  return {cls:'ok',text:'Normal'};
}

function updateBadge(id, cardId, status){
  const b = document.getElementById(id);
  b.className = 'badge ' + status.cls;
  b.textContent = status.text;
  const card = document.getElementById(cardId);
  card.className = 'metric-card ' + status.cls;
}

function addAlert(text, type){
  const list = document.getElementById('alertList');
  const noAlert = list.querySelector('.no-alerts');
  if(noAlert) noAlert.remove();
  const item = document.createElement('div');
  item.className = 'alert-item ' + type;
  item.innerHTML =
    `<div class="alert-dot ${type}"></div>
     <div>
       <div class="alert-text">${text}</div>
       <div class="alert-time">${new Date().toLocaleTimeString('en-GB',{hour12:false})}</div>
     </div>`;
  list.prepend(item);
  while(list.children.length > 10) list.lastChild.remove();
}

// ---- WebSocket ----
const ws = new WebSocket('wss://baby-monitor-server-0st8.onrender.com/dashboard');

ws.onopen  = () => setConnected(true);
ws.onclose = () => setConnected(false);

ws.onmessage = (event) => {
  const msg = JSON.parse(event.data);

  if(msg.type === 'sensor'){

    if(msg.topic === 'babymonitor/temperature'){
      const obj = msg.data.object;
      document.getElementById('tempVal').innerHTML =
        obj.toFixed(1) + '<span class="metric-unit">°C</span>';
      const s = tempStatus(obj);
      updateBadge('tempBadge','tempCard',s);
      addPoint(tempChart,0,obj);
      tempChart.update('none');
    }

    if(msg.topic === 'babymonitor/radar'){
      const br = msg.data.breathing;
      const hr = msg.data.heartrate;
      const dist = msg.data.distance;
      const det  = msg.data.detected;

      document.getElementById('brVal').innerHTML =
        br.toFixed(0) + '<span class="metric-unit">bpm</span>';
      document.getElementById('hrVal').innerHTML =
        hr.toFixed(0) + '<span class="metric-unit">bpm</span>';
      document.getElementById('radarBr').textContent = br.toFixed(0) + ' bpm';
      document.getElementById('radarHr').textContent = hr.toFixed(0) + ' bpm';
      document.getElementById('distVal').textContent = dist.toFixed(2) + 'm';
      document.getElementById('detectLabel').textContent = det ? 'DETECTED' : 'NO SIGNAL';

      // progress bars — clamp to 0-100%
      document.getElementById('brBar').style.width = Math.min(100,Math.max(0,(br/60)*100))+'%';
      document.getElementById('hrBar').style.width = Math.min(100,Math.max(0,((hr-60)/120)*100))+'%';

      updateBadge('brBadge','brCard',brStatus(br));
      updateBadge('hrBadge','hrCard',hrStatus(hr));

      addPoint(brhrChart,0,br);
      addPoint(brhrChart,1,hr);
      brhrChart.update('none');
    }

    if(msg.topic === 'babymonitor/alerts'){
      addAlert(msg.data.condition, 'warn');
    }
  }

  if(msg.type === 'state' && msg.data){
    if(msg.data.temperature)
      addAlert('Dashboard reconnected — last temp: ' + msg.data.temperature.object.toFixed(1) + ' °C', 'info');
  }

  if(msg.type === 'audio'){
    const samples = msg.data.slice(0,80);
    audioChart.data.labels = samples.map((_,i)=>i);
    audioChart.data.datasets[0].data = samples;
    audioChart.update('none');
  }
};

// ---- Audio ----
let audioCtx;
function startAudio(){
  audioCtx = new (window.AudioContext||window.webkitAudioContext)({sampleRate:16000});
  document.getElementById('audioBtn').textContent = '🔊 Listening...';
}
</script>
</body>
</html>
